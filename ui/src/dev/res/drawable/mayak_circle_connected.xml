<?xml version="1.0" encoding="utf-8"?>
<!-- НОВЫЙ дизайн (dev): «премиальная» кнопка — «Защищено». Яркий accent-ободок + насыщенное радиальное
     свечение (свет сверху) с внутренним бликом. Прод — плоский вариант из main/res. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="@color/mayak_accent" />
        </shape>
    </item>
    <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="95%"
                android:centerX="0.5"
                android:centerY="0.35"
                android:startColor="@color/mayak_circle_glow_in"
                android:centerColor="@color/mayak_circle_glow_out"
                android:endColor="@color/mayak_circle_glow_out" />
            <stroke android:width="3dp" android:color="@color/mayak_accent" />
        </shape>
    </item>
</layer-list>
