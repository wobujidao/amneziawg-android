<?xml version="1.0" encoding="utf-8"?>
<!-- DEV «Beacon» — кнопка «Защищено» как зажжённая лампа маяка: тёплое ядро (glow_in) → холодный
     cyan (glow_out) → глубокий синий край, даёт объём светящейся сферы. Только dev-сборка. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="@color/mayak_accent" />
        </shape>
    </item>
    <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="98%"
                android:centerX="0.5"
                android:centerY="0.38"
                android:startColor="@color/mayak_circle_glow_in"
                android:centerColor="@color/mayak_circle_glow_out"
                android:endColor="#0B5F98" />
            <stroke android:width="3dp" android:color="@color/mayak_accent" />
        </shape>
    </item>
</layer-list>
