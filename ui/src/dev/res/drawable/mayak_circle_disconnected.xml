<?xml version="1.0" encoding="utf-8"?>
<!-- НОВЫЙ дизайн (dev): «премиальная» кнопка — «Отключено». Мягкое внешнее кольцо-ореол + основной диск
     с лёгкой глубиной (радиальный градиент, свет сверху) и приглушённым кольцом. Прод рендерит плоский
     вариант из main/res. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="@color/mayak_circle_halo_mid" />
        </shape>
    </item>
    <item android:top="5dp" android:bottom="5dp" android:left="5dp" android:right="5dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="82%"
                android:centerX="0.5"
                android:centerY="0.32"
                android:startColor="@color/mayak_bg_grad_top"
                android:endColor="@color/mayak_circle_fill_off" />
            <stroke android:width="2dp" android:color="@color/mayak_circle_ring_off" />
        </shape>
    </item>
</layer-list>
