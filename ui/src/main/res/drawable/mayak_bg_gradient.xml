<?xml version="1.0" encoding="utf-8"?>
<!-- Фон экрана: мягкий вертикальный градиент. Цвета семантические (mayak_bg_grad_*) —
     в светлой теме кремовый, в тёмной навигационный синий (через values-night/colors.xml). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="@color/mayak_bg_grad_top"
        android:centerColor="@color/mayak_bg_grad_center"
        android:endColor="@color/mayak_bg_grad_bottom"
        android:type="linear" />
</shape>
