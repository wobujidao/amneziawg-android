<?xml version="1.0" encoding="utf-8"?>
<!-- Бейдж-маяк с отступом ~16%, чтобы целиком попасть в безопасную зону adaptive-icon
     (внутренние 66 из 108 dp) и не обрезаться круглой/квадратной маской лаунчера. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/ic_launcher_foreground"
    android:insetLeft="16%"
    android:insetTop="16%"
    android:insetRight="16%"
    android:insetBottom="16%" />
