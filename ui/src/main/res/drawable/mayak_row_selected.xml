<?xml version="1.0" encoding="utf-8"?>
<!-- Фон ВЫБРАННОЙ строки-страны: тональная заливка + левый акцентный «бар» (Happ-стиль). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/mayak_row_selected_bg" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- левый акцентный бар -->
    <item android:width="5dp" android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="@color/mayak_accent" />
            <corners
                android:topLeftRadius="14dp"
                android:bottomLeftRadius="14dp" />
        </shape>
    </item>
</layer-list>
