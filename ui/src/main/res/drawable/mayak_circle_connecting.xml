<?xml version="1.0" encoding="utf-8"?>
<!-- Круглая кнопка — «Подключение…». Премиум-вид (одобрен 2026-07-22): тёплое внешнее кольцо-ореол (accent) +
     диск с лёгкой глубиной и ярким accent-кольцом. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="@color/mayak_accent" />
        </shape>
    </item>
    <item android:top="5dp" android:bottom="5dp" android:left="5dp" android:right="5dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="82%"
                android:centerX="0.5"
                android:centerY="0.32"
                android:startColor="@color/mayak_circle_glow_in"
                android:endColor="@color/mayak_circle_fill_pending" />
            <stroke android:width="3dp" android:color="@color/mayak_accent" />
        </shape>
    </item>
</layer-list>
