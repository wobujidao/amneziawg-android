<?xml version="1.0" encoding="utf-8"?>
<!-- Пилюля-значок «IPv6»: тонкая акцентная обводка + лёгкая заливка. Зажигается ТОЛЬКО когда IPv6
     реально работает через туннель (проба api6.ipify.org прошла) — честный сигнал (SPEC-0014). -->
