<?xml version="1.0" encoding="utf-8"?>
<!--
  Доверие к нашему серверному сертификату ядра «Маяк». Ядро держит TLS-серт, выпущенный НАШИМ CA
  (cmd/mayak-ca), а не публичным — поэтому телефон должен доверять нашему CA для адреса ядра.
  В приложение зашит только ПУБЛИЧНЫЙ сертификат CA (res/raw/mayak_ca.pem) — это не секрет.
  Приватный ключ CA остаётся на сервере и в приложение/репо НЕ попадает.
-->
<network-security-config>
    <!-- По умолчанию: только TLS (без cleartext), системные корни. Под это попадает публичный
         домен api.mayakvpn.ru с обычным сертификатом Let's Encrypt — спец-настройки не нужны. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Ядро по IP (серт выпущен НАШИМ Mayak Core CA) — доверяем нашему CA только для адреса ядра.
         IP-фолбэк на случай DNS-блокировки домена api.mayakvpn.ru в РФ. Новое ядро — 138.16.128.138
         (с 2026-07-18); старый 45.132.18.167 (RuVDS) выключается ~07-23, оставлен на переходный период.
         ⚠️ Серт client-api :8443 нового ядра ДОЛЖЕН иметь SAN=IP:138.16.128.138 (иначе hostname-проверка
         не пройдёт). См. FINDING-app-ip-fallback-stale-core-2026-07-22. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="false">138.16.128.138</domain>
        <domain includeSubdomains="false">45.132.18.167</domain>
        <trust-anchors>
            <certificates src="@raw/mayak_ca" />
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
