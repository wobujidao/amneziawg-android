<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="AmneziaWgTheme.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorSurface</item>
    </style>

    <style name="AppThemeBase" parent="AmneziaWgTheme">
        <item name="materialCardViewStyle">@style/AmneziaWgTheme.MaterialCardView</item>
        <item name="toolbarStyle">@style/AmneziaWgTheme.Toolbar</item>
        <item name="bottomSheetDialogTheme">@style/AmneziaWgTheme.BottomSheetDialog</item>
        <item name="android:statusBarColor">@null</item>
    </style>

    <!-- Various additional API-specific features in values-v*/styles.xml -->
    <style name="AppTheme" parent="AppThemeBase" />

    <style name="AmneziaWgTheme.MaterialCardView" parent="Widget.Material3.CardView.Elevated">
        <!-- Унифицировано на шкалу «Маяк» (radius.xs): убирает legacy 4dp (см. дизайн-ревью §3.1) -->
        <item name="cornerRadius">@dimen/mayak_radius_xs</item>
        <item name="contentPadding">@dimen/mayak_space_2</item>
    </style>

    <style name="AmneziaWgTheme.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="NoBackgroundTheme" parent="AppTheme">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="colorPrimaryDark">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="TvTheme" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Экран «Маяк»: DayNight — следует светлому/тёмному режиму телефона.
         Фон/статусбар/навбар берутся из семантических цветов (флипаются в values-night). -->
    <style name="MayakTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="materialCardViewStyle">@style/AmneziaWgTheme.MaterialCardView</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@color/mayak_bg</item>
        <item name="android:colorBackground">@color/mayak_bg</item>
        <item name="colorSurface">@color/mayak_surface</item>
        <item name="colorOnSurface">@color/mayak_on_surface</item>
        <item name="colorPrimary">@color/mayak_primary</item>
        <item name="colorOnPrimary">@color/mayak_on_primary</item>
        <item name="android:statusBarColor">@color/mayak_statusbar</item>
        <item name="android:navigationBarColor">@color/mayak_statusbar</item>
        <!-- цвет текста/иконок в диалогах (язык/тема) тоже следует режиму -->
        <item name="android:textColorPrimary">@color/mayak_on_surface</item>
        <item name="android:textColorSecondary">@color/mayak_on_surface_muted</item>
    </style>

    <!-- === Брендовые компоненты «Маяк» (цвета семантические → корректный контраст в обоих режимах) === -->

    <style name="Mayak.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/mayak_on_bg</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Mayak.Tagline" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/mayak_on_bg_muted</item>
    </style>

    <style name="Mayak.CardTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/mayak_on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Mayak.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cornerRadius">@dimen/mayak_radius_md</item>
        <item name="cardBackgroundColor">@color/mayak_surface</item>
        <item name="cardElevation">@dimen/mayak_space_2</item>
        <item name="contentPadding">@dimen/mayak_space_5</item>
        <!-- Тонкая обводка: в светлой теме прозрачна, в тёмной — контур (карточка не сливается с navy) -->
        <item name="strokeColor">@color/mayak_card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Строка листа «Подробности подключения»: слева колонка label/value, справа — опц. кнопка копирования. -->
    <style name="Mayak.DetailRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Mayak.DetailRow.TextCol">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="Mayak.DetailRow.Label" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/mayak_on_bg_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:layout_marginBottom">2dp</item>
    </style>

    <style name="Mayak.DetailRow.Value" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/mayak_on_bg</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Mayak.DetailRow.Value.Mono">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Mayak.DetailRow.Divider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/mayak_divider</item>
    </style>

    <style name="Mayak.DetailRow.Copy" parent="">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:padding">8dp</item>
        <item name="android:src">@drawable/ic_copy</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:tint">@color/mayak_on_bg_muted</item>
    </style>

    <style name="Mayak.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/mayak_outline</item>
        <item name="hintTextColor">@color/mayak_outline</item>
        <item name="android:textColorHint">@color/mayak_on_surface_muted</item>
        <item name="boxCornerRadiusTopStart">@dimen/mayak_radius_sm</item>
        <item name="boxCornerRadiusTopEnd">@dimen/mayak_radius_sm</item>
        <item name="boxCornerRadiusBottomStart">@dimen/mayak_radius_sm</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/mayak_radius_sm</item>
        <item name="boxBackgroundColor">@color/mayak_field_bg</item>
        <item name="materialThemeOverlay">@style/Mayak.TextInput.Overlay</item>
    </style>

    <!-- Цвет вводимого текста и курсора в полях (читаемый в обоих режимах) -->
    <style name="Mayak.TextInput.Overlay">
        <item name="colorOnSurface">@color/mayak_field_on</item>
        <item name="android:textColorPrimary">@color/mayak_field_on</item>
        <item name="colorPrimary">@color/mayak_outline</item>
    </style>

    <style name="Mayak.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/mayak_primary</item>
        <item name="android:textColor">@color/mayak_on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/mayak_radius_sm</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Mayak.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/mayak_outline</item>
        <item name="android:textColor">@color/mayak_on_surface</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="cornerRadius">@dimen/mayak_radius_sm</item>
        <item name="android:minHeight">50dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Mayak.Button.Country" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/mayak_field_bg</item>
        <item name="android:textColor">@color/mayak_on_surface</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="cornerRadius">@dimen/mayak_radius_sm</item>
        <item name="android:minHeight">56dp</item>
        <item name="icon">@drawable/ic_arrow_back</item>
        <item name="iconGravity">end</item>
        <item name="iconTint">@color/mayak_outline</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Mayak.Button.Danger" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/mayak_red</item>
        <item name="android:textColor">@color/mayak_red</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="cornerRadius">@dimen/mayak_radius_sm</item>
        <item name="android:minHeight">50dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Иконки-кнопки в шапке (тема/настройки): тинт следует фону -->
    <style name="Mayak.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/mayak_on_bg</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="iconTint">@color/mayak_on_bg</item>
    </style>
</resources>
