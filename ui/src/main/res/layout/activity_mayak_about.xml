<?xml version="1.0" encoding="utf-8"?>
<!-- «О приложении»: версия, на чём основано (AmneziaWG / amneziawg-go / протокол 2.0),
     лицензия, открытый код, стабы политики/условий. Брендовый Material 3, DayNight. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mayak_bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- Шапка: назад + заголовок -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start|center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mayak_about_back"
                    style="@style/Mayak.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:contentDescription="@string/mayak_back"
                    app:icon="@drawable/ic_arrow_back"
                    app:iconTint="@color/mayak_on_bg"
                    app:iconSize="24dp"
                    android:text="" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/mayak_about"
                    android:textAppearance="@style/Mayak.Title"
                    android:textSize="24sp" />
            </LinearLayout>

            <!-- Логотип + название + версия -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/mayak_logo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/app_name"
                        android:textAppearance="@style/Mayak.CardTitle"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/mayak_tagline"
                        android:textColor="@color/mayak_on_surface_muted"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/mayak_about_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/mayak_on_surface_muted"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText"
                        android:text="v—" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Основано на -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mayak_based_on"
                        android:textAppearance="@style/Mayak.CardTitle" />

                    <TextView
                        android:id="@+id/mayak_about_basedon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingMultiplier="1.2"
                        android:textColor="@color/mayak_on_surface"
                        android:textSize="14sp"
                        tools:ignore="HardcodedText"
                        android:text="—" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Лицензия + открытый код -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mayak_license"
                        android:textAppearance="@style/Mayak.CardTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.2"
                        android:textColor="@color/mayak_on_surface"
                        android:textSize="14sp"
                        android:text="@string/mayak_license_line" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_about_oss"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:icon="@drawable/ic_action_open"
                        app:iconGravity="textStart"
                        app:iconTint="@color/mayak_outline"
                        android:text="@string/mayak_oss_licenses" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Правовое (стабы) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingMultiplier="1.2"
                        android:textColor="@color/mayak_on_surface"
                        android:textSize="14sp"
                        android:text="@string/mayak_about_nologs" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_about_privacy"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:iconGravity="textStart"
                        android:text="@string/mayak_privacy_policy" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_about_terms"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:iconGravity="textStart"
                        android:text="@string/mayak_terms" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
