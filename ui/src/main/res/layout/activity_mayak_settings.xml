<?xml version="1.0" encoding="utf-8"?>
<!-- Настройки «Маяк»: внешний вид (тема+язык) и диагностика (отправить/посмотреть лог, о приложении).
     Material 3, DayNight, брендовый градиент. Группировка по секциям, понятные иконки, акцент на
     «Отправить лог» (главное действие для разбора проблем подключения). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mayak_bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="32dp">

            <!-- Шапка: назад + заголовок -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start|center_vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mayak_settings_back"
                    style="@style/Mayak.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:contentDescription="@string/mayak_back"
                    app:icon="@drawable/ic_arrow_back"
                    app:iconTint="@color/mayak_on_bg"
                    app:iconSize="24dp"
                    android:text="" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/mayak_settings"
                    android:textAppearance="@style/Mayak.Title"
                    android:textSize="24sp" />
            </LinearLayout>

            <!-- ===== Внешний вид ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mayak_settings_appearance"
                        android:textAppearance="@style/Mayak.CardTitle" />

                    <!-- Тема -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/mayak_theme"
                        android:textColor="@color/mayak_on_surface"
                        android:textAppearance="@style/Mayak.Tagline" />

                    <RadioGroup
                        android:id="@+id/mayak_theme_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/mayak_theme_system"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:textColor="@color/mayak_on_surface"
                            android:buttonTint="@color/mayak_outline"
                            android:text="@string/mayak_theme_system" />

                        <RadioButton
                            android:id="@+id/mayak_theme_light"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:textColor="@color/mayak_on_surface"
                            android:buttonTint="@color/mayak_outline"
                            android:text="@string/mayak_theme_light" />

                        <RadioButton
                            android:id="@+id/mayak_theme_dark"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:textColor="@color/mayak_on_surface"
                            android:buttonTint="@color/mayak_outline"
                            android:text="@string/mayak_theme_dark" />
                    </RadioGroup>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/mayak_outline"
                        android:alpha="0.3" />

                    <!-- Язык (текст с текущим языком ставится в коде) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_settings_language"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_settings"
                        app:iconGravity="textStart"
                        app:iconTint="@color/mayak_outline"
                        android:text="@string/mayak_language" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Сеть ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mayak_settings_network"
                        android:textAppearance="@style/Mayak.CardTitle" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/mayak_settings_ipv6"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:minHeight="48dp"
                        android:textColor="@color/mayak_on_surface"
                        android:text="@string/mayak_settings_ipv6" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/mayak_settings_ipv6_hint"
                        android:textColor="@color/mayak_on_surface"
                        android:alpha="0.8"
                        android:textAppearance="@style/Mayak.Tagline" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Диагностика и помощь ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mayak_settings_diagnostics"
                        android:textAppearance="@style/Mayak.CardTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="12dp"
                        android:text="@string/mayak_settings_diag_hint"
                        android:textColor="@color/mayak_on_surface"
                        android:alpha="0.8"
                        android:textAppearance="@style/Mayak.Tagline" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_settings_send_log"
                        style="@style/Mayak.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_upload"
                        app:iconGravity="textStart"
                        android:text="@string/mayak_settings_send_log" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_settings_logs"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:icon="@drawable/ic_action_open"
                        app:iconGravity="textStart"
                        app:iconTint="@color/mayak_outline"
                        android:text="@string/mayak_settings_logs_view" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_settings_about"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:icon="@drawable/ic_info"
                        app:iconGravity="textStart"
                        app:iconTint="@color/mayak_outline"
                        android:text="@string/mayak_about" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Выход из аккаунта -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/mayak_settings_logout"
                style="@style/Mayak.Button.Danger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/mayak_logout" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
