<?xml version="1.0" encoding="utf-8"?>
<!-- Экран входа «Маяк Networks»: брендовый градиентный фон, логотип-маяк, карточка с формой. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mayak_bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="@dimen/mayak_space_6"
            android:paddingEnd="@dimen/mayak_space_6"
            android:paddingTop="@dimen/mayak_space_5"
            android:paddingBottom="@dimen/mayak_space_7">

            <!-- Шапка: слева — переключатель темы (солнце/луна/авто), справа — язык.
                 Тап-таргеты 48dp (доступность, см. дизайн-ревью §3.6). -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mayak_theme_button"
                    style="@style/Mayak.Button.Text"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:minWidth="48dp"
                    android:minHeight="48dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="@string/mayak_theme"
                    app:icon="@drawable/ic_theme_system"
                    app:iconGravity="textStart"
                    app:iconTint="@color/mayak_on_bg"
                    app:iconSize="24dp"
                    app:iconPadding="0dp"
                    android:text="" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mayak_language_button"
                    style="@style/Mayak.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:minHeight="48dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingStart="@dimen/mayak_space_3"
                    android:paddingEnd="@dimen/mayak_space_3"
                    app:icon="@drawable/ic_settings"
                    app:iconTint="@color/mayak_on_bg"
                    app:iconSize="18dp"
                    android:text="@string/mayak_language" />
            </LinearLayout>

            <ImageView
                android:id="@+id/mayak_logo"
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:layout_marginTop="@dimen/mayak_space_3"
                android:importantForAccessibility="no"
                android:src="@drawable/mayak_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mayak_space_4"
                android:text="@string/app_name"
                android:textAppearance="@style/Mayak.Title" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mayak_space_2"
                android:text="@string/mayak_tagline"
                android:textAppearance="@style/Mayak.Tagline" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mayak_space_6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/mayak_login_layout"
                        style="@style/Mayak.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/mayak_email_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/mayak_login"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/mayak_password_layout"
                        style="@style/Mayak.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/mayak_space_4"
                        app:endIconMode="password_toggle"
                        android:hint="@string/mayak_password_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/mayak_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_sign_in"
                        style="@style/Mayak.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/mayak_space_5"
                        android:text="@string/mayak_sign_in" />

                    <!-- Забыли пароль? — сброс по email-коду (POST /v1/auth/password/forgot+/reset). -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_forgot_password"
                        style="@style/Mayak.Button.Text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/mayak_space_1"
                        android:textColor="@color/mayak_outline"
                        android:text="@string/mayak_forgot_password" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/mayak_space_5"
                        android:layout_marginBottom="@dimen/mayak_space_4"
                        android:background="@color/mayak_divider" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_scan_qr"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_action_scan_qr_code"
                        app:iconGravity="textStart"
                        app:iconTint="@color/mayak_outline"
                        android:text="@string/mayak_scan_qr" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_paste_link"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/mayak_space_2"
                        app:icon="@drawable/ic_action_open"
                        app:iconGravity="textStart"
                        app:iconTint="@color/mayak_outline"
                        android:text="@string/mayak_paste_link" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_register"
                        style="@style/Mayak.Button.Text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/mayak_space_2"
                        android:textColor="@color/mayak_outline"
                        android:text="@string/mayak_register_cabinet" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/mayak_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mayak_space_4"
                android:gravity="center"
                android:textColor="@color/mayak_on_bg_muted"
                android:textSize="14sp" />

            <!-- Лёгкая ссылка на политику (согласие при использовании; биндинг — на сайте) -->
            <TextView
                android:id="@+id/mayak_consent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mayak_space_4"
                android:gravity="center"
                android:textColor="@color/mayak_on_bg_muted"
                android:textSize="12sp"
                android:text="@string/mayak_consent_note" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
