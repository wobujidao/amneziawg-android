<?xml version="1.0" encoding="utf-8"?>
<!-- Экран входа «Маяк VPN»: брендовый градиентный фон, логотип-маяк, карточка с формой. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mayak_bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- Переключатель языка справа сверху -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/mayak_language_button"
                style="@style/Mayak.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:icon="@drawable/ic_settings"
                app:iconTint="@color/mayak_on_bg"
                app:iconSize="18dp"
                android:text="@string/mayak_language" />

            <ImageView
                android:id="@+id/mayak_logo"
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:layout_marginTop="12dp"
                android:importantForAccessibility="no"
                android:src="@drawable/mayak_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/app_name"
                android:textAppearance="@style/Mayak.Title" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/mayak_tagline"
                android:textAppearance="@style/Mayak.Tagline" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/mayak_login_layout"
                        style="@style/Mayak.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/mayak_login_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/mayak_login"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/mayak_password_layout"
                        style="@style/Mayak.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:endIconMode="password_toggle"
                        android:hint="@string/mayak_password_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/mayak_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_sign_in"
                        style="@style/Mayak.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/mayak_sign_in" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="16dp"
                        android:background="@color/mayak_divider" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_scan_qr"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_action_scan_qr_code"
                        app:iconGravity="textStart"
                        app:iconTint="@color/mayak_outline"
                        android:text="@string/mayak_scan_qr" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_paste_link"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:icon="@drawable/ic_action_open"
                        app:iconGravity="textStart"
                        app:iconTint="@color/mayak_outline"
                        android:text="@string/mayak_paste_link" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/mayak_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:textColor="@color/mayak_on_bg_muted"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
