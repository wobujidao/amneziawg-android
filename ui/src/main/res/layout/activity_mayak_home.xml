<?xml version="1.0" encoding="utf-8"?>
<!-- Главный экран «Маяк VPN»: шапка с логотипом, карточка со списком стран, статус и действия. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mayak_bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- Шапка: слева — переключатель темы (солнце/луна/авто), справа — настройки -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mayak_theme_button"
                    style="@style/Mayak.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:contentDescription="@string/mayak_theme"
                    app:icon="@drawable/ic_theme_system"
                    app:iconTint="@color/mayak_on_bg"
                    app:iconSize="24dp"
                    app:iconPadding="0dp"
                    android:text="" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mayak_settings_button"
                    style="@style/Mayak.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:contentDescription="@string/mayak_settings"
                    app:icon="@drawable/ic_settings"
                    app:iconTint="@color/mayak_on_bg"
                    app:iconSize="22dp"
                    app:iconPadding="0dp"
                    android:text="" />
            </LinearLayout>

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="4dp"
                android:importantForAccessibility="no"
                android:src="@drawable/mayak_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/app_name"
                android:textAppearance="@style/Mayak.Title"
                android:textSize="24sp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mayak_pick_country"
                        android:textAppearance="@style/Mayak.CardTitle" />

                    <LinearLayout
                        android:id="@+id/mayak_dirs_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/mayak_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/mayak_text_muted"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mayak_disconnect"
                style="@style/Mayak.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/mayak_accent"
                android:textColor="@color/mayak_navy"
                android:text="@string/mayak_disconnect" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mayak_logout"
                style="@style/Mayak.Button.Danger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/mayak_logout" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
