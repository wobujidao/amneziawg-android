<?xml version="1.0" encoding="utf-8"?>
<!-- Главный экран «Маяк Networks» в стиле Happ: шапка (тема/настройки), большая круглая
     кнопка-подключение с состояниями + таймер сессии, ниже — список стран с флагами. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mayak_bg_gradient">

    <!-- Самый нижний слой: абстрактная сеть/карта (узлы + дуги + бегущие частицы), тихая,
         рисуется на Canvas без сети/SDK. Круг и список — поверх неё. -->
    <org.amnezia.awg.mayak.NetworkBackgroundView
        android:id="@+id/mayak_network_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <!-- Верх экрана фиксирован (шапка / кнопка / статус), а прокручивается ТОЛЬКО список стран
         внутри карточки (правка владельца 2026-07-18). Поэтому корень — LinearLayout, не ScrollView. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

            <!-- Шапка (правка владельца 2026-07-18): слева — тема (солнце/луна/авто),
                 ПО ЦЕНТРУ — селектор пресета split-туннеля (SPEC-0028), справа — настройки.
                 Переключатель языка убран с главной — он теперь только в настройках. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mayak_theme_button"
                    style="@style/Mayak.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:contentDescription="@string/mayak_theme"
                    app:icon="@drawable/ic_theme_system"
                    app:iconTint="@color/mayak_on_bg"
                    app:iconSize="24dp"
                    app:iconPadding="0dp"
                    android:text="" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Селектор пресета split-туннеля (SPEC-0028): имя активного пресета (тап → выбор/
                     создание/правка) + тумблер «применять пресет». Видимость — настройка
                     «Показывать пресеты на главном» (по умолч. ВКЛ). Текст имени ставится в коде. -->
                <LinearLayout
                    android:id="@+id/mayak_preset_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Имя пресета: без иконки (правка владельца 2026-07-18 — «без 3х точек»),
                         компактно, имя влезает целиком (без maxWidth/ellipsize), шрифт помельче. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mayak_preset_name"
                        style="@style/Mayak.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:minHeight="34dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:maxLines="1"
                        android:textSize="12sp"
                        android:text="РФ напрямую" />

                    <!-- Тумблер «применять пресет»: уменьшен (scale 0.8) и подтянут вплотную —
                         компактнее, чтобы имя пресета помещалось целиком (правка владельца). -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/mayak_preset_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="-2dp"
                        android:scaleX="0.8"
                        android:scaleY="0.8" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mayak_settings_button"
                    style="@style/Mayak.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:contentDescription="@string/mayak_settings"
                    app:icon="@drawable/ic_settings"
                    app:iconTint="@color/mayak_on_bg"
                    app:iconSize="22dp"
                    app:iconPadding="0dp"
                    android:text="" />
            </LinearLayout>

            <!-- Центр: волны (ripple) + внешний ореол (glow) + круглая кнопка подключения.
                 marginTop уменьшен (space_5→space_2) — кнопка выше на экране (правка владельца 2026-07-02). -->
            <FrameLayout
                android:layout_width="256dp"
                android:layout_height="256dp"
                android:layout_marginTop="@dimen/mayak_space_2">

                <!-- Концентрические волны от кнопки (sonar/активация при подключении) -->
                <org.amnezia.awg.mayak.RippleView
                    android:id="@+id/mayak_ripple"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no" />

                <!-- Ореол за кругом: больше круга, выходит за его границы. Альфа меняется кодом. -->
                <View
                    android:id="@+id/mayak_connect_glow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/mayak_circle_glow"
                    android:alpha="0"
                    android:importantForAccessibility="no" />

                <FrameLayout
                    android:id="@+id/mayak_connect_circle"
                    android:layout_width="176dp"
                    android:layout_height="176dp"
                    android:layout_gravity="center"
                    android:background="@drawable/mayak_circle_disconnected"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/mayak_a11y_connect">

                    <ImageView
                        android:id="@+id/mayak_connect_icon"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_power"
                        app:tint="@color/mayak_circle_icon_off" />
                </FrameLayout>
            </FrameLayout>

            <!-- Статус + блок инфо (время/IP/пинг) подтянуты ближе к кнопке (space_4→space_2, правка владельца) -->
            <TextView
                android:id="@+id/mayak_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mayak_space_2"
                android:gravity="center"
                android:textColor="@color/mayak_on_bg"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="@string/mayak_status_disconnected" />

            <!-- Таймер сессии (виден только при подключении) -->
            <TextView
                android:id="@+id/mayak_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mayak_space_1"
                android:gravity="center"
                android:textColor="@color/mayak_on_bg_muted"
                android:textSize="15sp"
                android:visibility="gone"
                tools:ignore="HardcodedText"
                android:text="00:00:00" />

            <!-- Внешний IP (виден при подключении) -->
            <TextView
                android:id="@+id/mayak_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:textColor="@color/mayak_on_bg_muted"
                android:textSize="13sp"
                android:visibility="gone"
                android:text="" />

            <!-- Компактная строка: пинг + значок IPv6 в ОДНУ линию (правка владельца: меньше строк на главном).
                 Каждый элемент показывается/прячется кодом независимо; при отключении строка схлопывается. -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mayak_space_1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/mayak_ping"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/mayak_on_bg_muted"
                    android:textSize="14sp"
                    android:visibility="gone"
                    android:text="" />

                <!-- Значок «IPv6» (только когда IPv6 реально работает через туннель — честно) -->
                <TextView
                    android:id="@+id/mayak_ipv6_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/mayak_bg_ipv6_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:gravity="center"
                    android:textColor="@color/mayak_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:ignore="HardcodedText"
                    android:text="IPv6" />
            </LinearLayout>

            <!-- Скорость (↓/↑; включается в настройках) — одна мелкая строка -->
            <TextView
                android:id="@+id/mayak_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="@color/mayak_on_bg_muted"
                android:textSize="13sp"
                android:visibility="gone"
                android:text="" />

            <!-- Список стран. Карточка занимает всё оставшееся место (weight=1), а список внутри
                 прокручивается сам (правка владельца 2026-07-18): верх экрана остаётся на месте. -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="@dimen/mayak_space_4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/mayak_pick_country"
                            android:textAppearance="@style/Mayak.CardTitle" />

                        <!-- SPEC-0031: режим сортировки (Авто/Пинг/Свои) — циклический переключатель. -->
                        <TextView
                            android:id="@+id/mayak_sort_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/mayak_sort_auto"
                            android:textColor="?attr/colorPrimary"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/mayak_refresh_dirs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/mayak_refresh"
                            android:textColor="?attr/colorPrimary"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <!-- Прокрутка списка внутри карточки; разделители между строками — через
                         showDividers="middle" на самом контейнере строк (divider = 1dp линия). -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="4dp"
                        android:scrollbars="none"
                        android:clipToPadding="false">

                        <LinearLayout
                            android:id="@+id/mayak_dirs_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:divider="@drawable/mayak_row_divider"
                            android:showDividers="middle" />
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
</FrameLayout>
