<?xml version="1.0" encoding="utf-8"?>
<!-- Главный экран «Маяк VPN» в стиле Happ: шапка (тема/настройки), большая круглая
     кнопка-подключение с состояниями + таймер сессии, ниже — список стран с флагами. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mayak_bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <!-- Шапка: слева — переключатель темы (солнце/луна/авто), справа — настройки -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mayak_theme_button"
                    style="@style/Mayak.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:contentDescription="@string/mayak_theme"
                    app:icon="@drawable/ic_theme_system"
                    app:iconTint="@color/mayak_on_bg"
                    app:iconSize="24dp"
                    app:iconPadding="0dp"
                    android:text="" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mayak_settings_button"
                    style="@style/Mayak.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:contentDescription="@string/mayak_settings"
                    app:icon="@drawable/ic_settings"
                    app:iconTint="@color/mayak_on_bg"
                    app:iconSize="22dp"
                    app:iconPadding="0dp"
                    android:text="" />
            </LinearLayout>

            <!-- Центр: внешний ореол (glow) + круглая кнопка подключения поверх него -->
            <FrameLayout
                android:layout_width="256dp"
                android:layout_height="256dp"
                android:layout_marginTop="@dimen/mayak_space_5">

                <!-- Ореол за кругом: больше круга, выходит за его границы. Альфа меняется кодом. -->
                <View
                    android:id="@+id/mayak_connect_glow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/mayak_circle_glow"
                    android:alpha="0"
                    android:importantForAccessibility="no" />

                <FrameLayout
                    android:id="@+id/mayak_connect_circle"
                    android:layout_width="176dp"
                    android:layout_height="176dp"
                    android:layout_gravity="center"
                    android:background="@drawable/mayak_circle_disconnected"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/mayak_a11y_connect">

                    <ImageView
                        android:id="@+id/mayak_connect_icon"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_power"
                        app:tint="@color/mayak_circle_icon_off" />
                </FrameLayout>
            </FrameLayout>

            <!-- Статус -->
            <TextView
                android:id="@+id/mayak_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:textColor="@color/mayak_on_bg"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="@string/mayak_status_disconnected" />

            <!-- Таймер сессии (виден только при подключении) -->
            <TextView
                android:id="@+id/mayak_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="@color/mayak_on_bg_muted"
                android:textSize="15sp"
                android:visibility="gone"
                tools:ignore="HardcodedText"
                android:text="00:00:00" />

            <!-- Внешний IP (виден при подключении) -->
            <TextView
                android:id="@+id/mayak_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:textColor="@color/mayak_on_bg_muted"
                android:textSize="13sp"
                android:visibility="gone"
                android:text="" />

            <!-- Список стран -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Mayak.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mayak_pick_country"
                        android:textAppearance="@style/Mayak.CardTitle" />

                    <LinearLayout
                        android:id="@+id/mayak_dirs_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
