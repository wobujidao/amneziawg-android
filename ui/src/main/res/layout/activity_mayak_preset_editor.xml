<?xml version="1.0" encoding="utf-8"?>
<!-- SPEC-0028: полноэкранный редактор ОДНОГО пресета сплит-туннеля (аналог экрана
     «Режим VPN для приложений» BlancVPN). Сверху — имя пресета, карточка с тремя режимами
     (все / все кроме выбранных / только выбранные), счётчик «Выбрано X из Y», поиск и список
     приложений с галочками, снизу — кнопка «Сохранить». Список приложений — RecyclerView,
     занимает всё свободное место (weight=1), поэтому корень — LinearLayout, а НЕ ScrollView. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mayak_bg_gradient">

    <LinearLayout
        android:id="@+id/mayak_preset_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp">

        <!-- Шапка: назад + заголовок -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mayak_preset_back"
                style="@style/Mayak.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:contentDescription="@string/mayak_back"
                app:icon="@drawable/ic_arrow_back"
                app:iconTint="@color/mayak_on_bg"
                app:iconSize="24dp"
                android:text="" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/mayak_preset_editor_title"
                android:textAppearance="@style/Mayak.Title"
                android:textSize="24sp" />

            <!-- Удалить пресет: виден только для своего пресета (в коде).
                 Заголовок выше — 0dp+weight, поэтому кнопка всегда влезает справа (не срезается). -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/mayak_preset_delete"
                style="@style/Mayak.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="@color/mayak_red"
                android:visibility="gone"
                android:text="@string/mayak_preset_editor_delete" />
        </LinearLayout>

        <!-- Имя пресета: read-only при EXTRA_EDITABLE=false (системный пресет). -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/mayak_preset_name_layout"
            style="@style/Mayak.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/mayak_preset_editor_name_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/mayak_preset_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Карточка выбора режима: три строки с заголовком+подзаголовком и трейлинг-радиокнопкой.
             Мьютекс-выбор ведётся в коде (не через RadioGroup) — так строки могут иметь подзаголовки. -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Mayak.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Сворачиваемая шапка: показывает текущий режим; тап — раскрыть выбор.
                     По умолчанию тело свёрнуто, чтобы список приложений занимал больше места. -->
                <LinearLayout
                    android:id="@+id/mayak_preset_mode_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mayak_preset_editor_mode_label"
                            android:textColor="@color/mayak_on_surface"
                            android:textAppearance="@style/Mayak.CardTitle"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/mayak_preset_mode_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:textColor="@color/mayak_on_surface"
                            android:alpha="0.8"
                            android:textAppearance="@style/Mayak.Tagline"
                            tools:text="Все, кроме выбранных" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/mayak_preset_mode_chevron"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▾"
                        android:textColor="@color/mayak_on_surface"
                        android:textSize="18sp"
                        android:alpha="0.7"
                        android:paddingStart="8dp"
                        android:paddingEnd="4dp" />
                </LinearLayout>

                <!-- Тело выбора режима: свёрнуто по умолчанию (visibility=gone). -->
                <LinearLayout
                    android:id="@+id/mayak_preset_modes_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/mayak_divider" />

                <!-- Режим «Все приложения» → mode "all" -->
                <LinearLayout
                    android:id="@+id/mayak_preset_row_all"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mayak_preset_editor_mode_all"
                            android:textColor="@color/mayak_on_surface"
                            android:textAppearance="@style/Mayak.CardTitle"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="@string/mayak_preset_editor_mode_all_sub"
                            android:textColor="@color/mayak_on_surface"
                            android:alpha="0.8"
                            android:textAppearance="@style/Mayak.Tagline" />
                    </LinearLayout>

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/mayak_preset_radio_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/mayak_divider" />

                <!-- Режим «Все, кроме выбранных» → mode "exclude" -->
                <LinearLayout
                    android:id="@+id/mayak_preset_row_exclude"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mayak_preset_editor_mode_exclude"
                            android:textColor="@color/mayak_on_surface"
                            android:textAppearance="@style/Mayak.CardTitle"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="@string/mayak_preset_editor_mode_exclude_sub"
                            android:textColor="@color/mayak_on_surface"
                            android:alpha="0.8"
                            android:textAppearance="@style/Mayak.Tagline" />
                    </LinearLayout>

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/mayak_preset_radio_exclude"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/mayak_divider" />

                <!-- Режим «Только выбранные» → mode "include" -->
                <LinearLayout
                    android:id="@+id/mayak_preset_row_include"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mayak_preset_editor_mode_include"
                            android:textColor="@color/mayak_on_surface"
                            android:textAppearance="@style/Mayak.CardTitle"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="@string/mayak_preset_editor_mode_include_sub"
                            android:textColor="@color/mayak_on_surface"
                            android:alpha="0.8"
                            android:textAppearance="@style/Mayak.Tagline" />
                    </LinearLayout>

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/mayak_preset_radio_include"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>
                </LinearLayout><!-- /mayak_preset_modes_body -->
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Счётчик «Выбрано X из Y» (обновляется в коде). -->
        <TextView
            android:id="@+id/mayak_preset_counter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/mayak_on_bg"
            android:textAppearance="@style/Mayak.CardTitle"
            tools:text="Выбрано 3 из 42" />

        <!-- Поиск по названию приложения. -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/mayak_preset_search_layout"
            style="@style/Mayak.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/mayak_preset_editor_search_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/mayak_preset_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionSearch" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Область списка: RecyclerView + прогресс (загрузка) + подсказка для режима «Все». -->
        <FrameLayout
            android:id="@+id/mayak_preset_list_area"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mayak_preset_recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:scrollbars="vertical" />

            <ProgressBar
                android:id="@+id/mayak_preset_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <!-- Подсказка для режима «Все»: выбирать приложения не нужно. -->
            <TextView
                android:id="@+id/mayak_preset_all_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="24dp"
                android:text="@string/mayak_preset_editor_all_hint"
                android:textColor="@color/mayak_on_bg"
                android:alpha="0.8"
                android:textAppearance="@style/Mayak.Tagline"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Сохранить: текст меняется в коде на «Сохранить как свою копию» для системного пресета. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/mayak_preset_save"
            style="@style/Mayak.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/mayak_preset_editor_save" />
    </LinearLayout>
</FrameLayout>
