<?xml version="1.0" encoding="utf-8"?>
<!-- Экран блокировки приложения: брендовый градиент, логотип, подпись, кнопки «Разблокировать»/«Выйти».
     Системный BiometricPrompt показывается поверх автоматически (MayakLockActivity). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mayak_lock_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mayak_bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/mayak_logo"
            android:contentDescription="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/mayak_lock_title"
            android:textColor="@color/mayak_on_bg"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/mayak_lock_subtitle"
            android:textColor="@color/mayak_on_bg_muted"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mayak_lock_unlock"
            style="@style/Mayak.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/mayak_lock_unlock" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mayak_lock_exit"
            style="@style/Mayak.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/mayak_lock_exit" />
    </LinearLayout>
</FrameLayout>
