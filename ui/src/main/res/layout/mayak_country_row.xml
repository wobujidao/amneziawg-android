<?xml version="1.0" encoding="utf-8"?>
<!-- Строка-страна (Happ-стиль): флаг-эмодзи + название + шеврон. Выбранная подсвечивается
     фоном mayak_row_selected (левый акцентный бар). Тап = ВЫБОР (не подключение). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mayak_row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minHeight="60dp"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/mayak_row_flag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="28sp"
        android:importantForAccessibility="no"
        android:text="🌐" />

    <TextView
        android:id="@+id/mayak_row_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:textColor="@color/mayak_on_surface"
        android:textSize="16sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="—" />

    <ImageView
        android:id="@+id/mayak_row_chevron"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/mayak_on_surface_muted"
        xmlns:app="http://schemas.android.com/apk/res-auto" />
</LinearLayout>
