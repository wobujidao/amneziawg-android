<?xml version="1.0" encoding="utf-8"?>
<!-- Строка-страна (Happ-стиль): ВЕКТОРНЫЙ флаг + название + шеврон. Выбранная подсвечивается
     фоном mayak_row_selected (левый акцентный бар). Тап = ВЫБОР (не подключение). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mayak_row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minHeight="48dp"
    android:paddingStart="@dimen/mayak_space_3"
    android:paddingEnd="@dimen/mayak_space_3"
    android:paddingTop="@dimen/mayak_space_1"
    android:paddingBottom="@dimen/mayak_space_1"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/mayak_row_flag"
        android:layout_width="26dp"
        android:layout_height="18dp"
        android:importantForAccessibility="no"
        android:scaleType="fitXY"
        android:src="@drawable/flag_globe" />

    <!-- Название + город-подзаголовок (SPEC-0037): две строки как в утв. дизайне (approved-idle.png). -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/mayak_space_3"
        android:orientation="vertical">

        <TextView
            android:id="@+id/mayak_row_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/mayak_on_surface"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="—" />

        <TextView
            android:id="@+id/mayak_row_city"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/mayak_on_surface"
            android:alpha="0.6"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

    <!-- SPEC-0031 / запрос владельца 2026-07-11: ЦИФРА пинга (мс) телефон→сервер вместо полосок. -->
    <TextView
        android:id="@+id/mayak_row_ping"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="48dp"
        android:gravity="end"
        android:textSize="12sp"
        android:textStyle="bold"
        android:importantForAccessibility="no" />
</LinearLayout>
