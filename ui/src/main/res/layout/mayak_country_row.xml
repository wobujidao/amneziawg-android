<?xml version="1.0" encoding="utf-8"?>
<!-- Строка-страна (Happ-стиль): ВЕКТОРНЫЙ флаг + название + шеврон. Выбранная подсвечивается
     фоном mayak_row_selected (левый акцентный бар). Тап = ВЫБОР (не подключение). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mayak_row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/mayak_space_2"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minHeight="60dp"
    android:paddingStart="@dimen/mayak_space_3"
    android:paddingEnd="@dimen/mayak_space_3"
    android:paddingTop="@dimen/mayak_space_2"
    android:paddingBottom="@dimen/mayak_space_2"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/mayak_row_flag"
        android:layout_width="30dp"
        android:layout_height="22dp"
        android:importantForAccessibility="no"
        android:scaleType="fitXY"
        android:src="@drawable/flag_globe" />

    <TextView
        android:id="@+id/mayak_row_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/mayak_space_4"
        android:textColor="@color/mayak_on_surface"
        android:textSize="16sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="—" />

    <TextView
        android:id="@+id/mayak_row_ping"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/mayak_space_2"
        android:textColor="@color/mayak_on_surface_muted"
        android:textSize="13sp"
        android:maxLines="1"
        android:text="" />

    <ImageView
        android:id="@+id/mayak_row_chevron"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/mayak_on_surface_muted" />
</LinearLayout>
